---
import { Image } from "astro:assets";
import LogoHCTFooter from "../../../public/img/logoFooter.png";
---

<footer>
  <div class="bg-[#EDEDED] text-[#1C244B] py-10">
    <div class="w-90/100 mx-auto space-y-7">
      <div
        class="flex flex-col md:flex-row justify-between items-center gap-5 md:gap-0"
      >
        <div class="w-3/5 md:w-1/6">
          <Image
            src={LogoHCTFooter}
            alt="Logo Footer"
            format="png"
            quality="high"
          />
        </div>

        <div
          class="flex flex-col md:flex-row gap-0 md:gap-8 font-medium text-center md:text-left"
        >
          <ul>
            <li>Tecnología</li>
            <li>Aplicaciones</li>
            <li>Beneficios</li>
            <li>Funcionamiento</li>
          </ul>

          <ul>
            <li>Solicitar Información</li>
            <li>Escalabilidad</li>
            <li>Impacto</li>
          </ul>
        </div>
      </div>

      <div class="border border-white"></div>

      <div
        class="flex justify-between flex-col md:flex-row gap-5 md:gap-0 text-center md:text-left"
      >
        <p>© Hydro Cleaning Technology. Todos los derechos reservados.</p>
        <p>www.hctsolar.com</p>
      </div>
    </div>
  </div>

  <div class="text-[#EDEDED] bg-[#1C244B] text-center text-sm">
    Creado por Encodev
  </div>
</footer>
