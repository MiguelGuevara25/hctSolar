---
import SlideAplicaciones from "../ui/SlideAplicaciones.astro";
---

<section class="bg-white pt-70 md:pt-80">
  <div class="w-4/5 mx-auto space-y-10">
    <div class="space-y-3 text-center">
      <span class="uppercase">Aplicaciones</span>

      <h2 class="font-archivo text-4xl font-light">
        Diseñado para
        <span class="font-bold border-b-2 border-[#FF7C00]"> adaptarse </span>
        a cualquier configuración solar
      </h2>
    </div>

    <SlideAplicaciones />
  </div>
</section>
