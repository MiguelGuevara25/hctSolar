---
import Form from "../ui/Form.astro";
import { Image } from "astro:assets";
import LogoRILVerde from "../../../public/partners/LogoRILVerde.avif";
import LogoGreenSunVerde from "../../../public/partners/LogoGreenSunVerde.webp";
---

<section class="bg-white text-[#1C244B] py-10 md:py-20">
  <div class="w-90/100 mx-auto flex flex-col gap-6 md:gap-40 md:flex-row">
    <div class="space-y-3 basis-1/3">
      <span class="uppercase">Contacto</span>

      <h2 class="font-archivo text-4xl font-light">
        <span class="font-bold border-b-2 border-[#FF7C00]">
          Optimice el rendimiento
        </span>
        de su planta solar
      </h2>

      <p>
        Contáctenos para recibir información técnica, evaluar su proyecto o
        solicitar una demostración de la tecnología HCT.
      </p>

      <p>info@hctsolar.com</p>
    </div>

    <div class="space-y-5 basis-2/3">
      <Form />

      <div class="flex justify-between gap-6 items-center flex-col md:flex-row">
        <div class="w-2/3 h-28 md:w-full">
          <Image
            class="h-full object-contain"
            src={LogoGreenSunVerde}
            alt="Green Sun Verde"
            format="webp"
            quality="low"
          />
        </div>

        <div class="w-2/3 h-28 md:w-full">
          <Image
            class="h-full object-contain"
            src={LogoRILVerde}
            alt="RIL Verde"
            format="avif"
            quality="low"
          />
        </div>
      </div>
    </div>
  </div>
</section>
