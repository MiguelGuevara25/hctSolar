---
import FieldForm from "./FieldForm.astro";

interface Pais {
  name: string;
}

const response = await fetch("https://www.apicountries.com/countries");
const paises: Pais[] = await response.json();
---

<div class="bg-form p-2.5 rounded-[50px]">
  <form class="bg-white rounded-[45px] p-8 md:p-10 space-y-5">
    <div class="grid md:grid-cols-2 grid-cols-1 gap-6">
      <FieldForm label="Nombre" type="text" />
      <FieldForm label="Apellido" type="text" />
      <FieldForm label="Nombre de la empresa" type="text" />
      <FieldForm label="Correo corporativo" type="email" />
      <FieldForm label="Teléfono" type="tel" />

      <div class="flex flex-col w-full">
        <label for="pais">País*</label>
        <select
          class="bg-[#EDEDED] rounded-lg px-3 py-1.5 focus:outline-none text-sm"
          name="pais"
          id="pais"
        >
          <option value=""></option>
          {paises.map((pais) => <option>{pais.name}</option>)}
        </select>
      </div>
    </div>

    <div class="flex justify-end">
      <button class="bg-btn-form text-white px-6 py-2 rounded-4xl">
        Siguiente
      </button>
    </div>
  </form>
</div>
